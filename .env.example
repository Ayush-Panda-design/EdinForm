# =============================================================================
# FormCraft — Environment Variables
# =============================================================================

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/formcraft

# API Server
PORT=8000
NODE_ENV=development
BASE_URL=http://localhost:8000
APP_URL=http://localhost:3000

# Security — REQUIRED in production
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-here-at-least-32-chars

# Optional: Upstash Redis — distributed rate limiting (falls back to in-memory)
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=xxx

# Optional: Resend — email notifications (falls back to console.log)
# RESEND_API_KEY=re_xxx
# EMAIL_FROM=FormCraft <noreply@formcraft.io>

# Optional: Snyk — dependency security scanning
# SNYK_TOKEN=xxx
